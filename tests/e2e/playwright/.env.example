# Playwright E2E Test Environment Variables
# Copy this file to .env and update with your test environment details

# Base URL of the application under test
BASE_URL=http://127.0.0.1

# Valid customer credentials
CUSTOMER_EMAIL=pub@qloapps.com
CUSTOMER_PASSWORD=123456789

# Invalid login scenarios
INVALID_EMAIL=unregistered_user@example.com
INVALID_PASSWORD=WrongPassword@123

# Invalid email format for validation testing
INVALID_EMAIL_FORMAT=invalid-email-format

# Security test inputs (SQL injection and XSS)
SQL_INJECTION_EMAIL=' OR '1'='1
XSS_EMAIL=<script>alert('xss')</script>

# Optional: Additional test data
# Add more environment variables as needed for your tests
